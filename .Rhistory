COI_NORM=OPPORTUNITY_SCORE_COI_NATL_NORM
,COI_OVERALL_LEVEL=OPPORTUNITY_LVL_COI_NATL_NORM
),keyby = STUDY_ID][demog]
demog[,COI_HIGH:=COI_OVERALL_LEVEL %in% c("High","Very High","Moderate")]
#MEDICATIONS PROCESSING #####
medications[,GENERIC_MEDICATION_NAME:=toupper(GENERIC_MEDICATION_NAME)]
medications[,DRUG_NAME:=toupper(str_extract(GENERIC_MEDICATION_NAME,'([a-zA-z]*)(?=[ 0-9]|$)'))]
medications[DRUG_NAME=="",DRUG_NAME:='CLONIDINE']#fix clonidine suspension
#cb(medications[!IS_ALPHA_ANTAGONIST&!IS_ATOMOXETINE&!IS_TRUE_STIMULANT,.N,by=DRUG_NAME])# medications not in ADHD list, reviewed and can be removed
medications<-medications[IS_ALPHA_ANTAGONIST|IS_ATOMOXETINE|IS_TRUE_STIMULANT]#removed 17000 medication orders (likely some expired)
#determine start date from order date if no start date
medications[is.na(MED_START_AGE_DAYS),MED_START_AGE_DAYS:=MED_ORDER_AGE_DAYS]
#determine an end date from start date if missing end date
medications[IS_TRUE_STIMULANT==TRUE,MED_END_AGE_DAYS:=MED_START_AGE_DAYS+STIMULANT_END_DAY_LENGTH]
medications[is.na(MED_END_AGE_DAYS)&!IS_TRUE_STIMULANT,MED_END_AGE_DAYS:=MED_START_AGE_DAYS+NON_STIMULANT_END_DAY_LENGTH]
#medications[is.na(MED_END_AGE_DAYS)]#all products now with end date and start date
medications<-medications[!MED_END_AGE_DAYS<=MED_START_AGE_DAYS]#194 products with start date on/before end date, remove from analysis
#Join DEMOG to MEDICATIONS #####
medications<-demog[,.(START_INTERVENTION_AGE,START_FU_AGE,END_INTERVENTION_AGE,END_FU_AGE,PRE_INTERVENTION_PERIOD_START,PRE_INTERVENTION_PERIOD_END,START_POST_AGE,END_POST_AGE),keyby=STUDY_ID][medications]
#Medications relationship to study periods
medications[,ACTIVE_START_INTERVENTION:=(MED_START_AGE_DAYS<=START_INTERVENTION_AGE&MED_END_AGE_DAYS>=START_INTERVENTION_AGE)]
medications[,ACTIVE_END_INTERVENTION:=(MED_START_AGE_DAYS<=END_INTERVENTION_AGE&MED_END_AGE_DAYS>=END_INTERVENTION_AGE)]
medications[,ACTIVE_END_FOLLOWUP:=(MED_START_AGE_DAYS<=END_FU_AGE&MED_END_AGE_DAYS>=END_FU_AGE)]
medications[,ACTIVE_END_POST:=(MED_START_AGE_DAYS<=END_POST_AGE&MED_END_AGE_DAYS>=END_POST_AGE)]
#medications that were ordered during intervenion/followup up - not necessarily new
medications[,START_DURING_INTERVENTION:=(MED_START_AGE_DAYS>START_INTERVENTION_AGE&MED_START_AGE_DAYS<END_INTERVENTION_AGE)]
medications[,START_DURING_FOLLOWUP:=(MED_START_AGE_DAYS>END_INTERVENTION_AGE&MED_START_AGE_DAYS<END_FU_AGE)]
medications[,START_DURING_POST:=(MED_START_AGE_DAYS>END_FU_AGE&MED_START_AGE_DAYS<END_POST_AGE)]
#Join MEDICAITONS to DEMOG
demog<-medications[ACTIVE_START_INTERVENTION==TRUE,.(COUNT_ACTIVE_START=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_START_INTERVENTION==TRUE&IS_TRUE_STIMULANT,.(COUNT_ACTIVE_START_STIMULANT=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_START_INTERVENTION==TRUE&IS_ATOMOXETINE,.(COUNT_ACTIVE_START_ATOMOX=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_START_INTERVENTION==TRUE&IS_ALPHA_ANTAGONIST,.(COUNT_ACTIVE_START_ALPHA=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_INTERVENTION==TRUE,.(COUNT_ACTIVE_END=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_INTERVENTION==TRUE&IS_TRUE_STIMULANT,.(COUNT_END_STIMULANT=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_INTERVENTION==TRUE&IS_ATOMOXETINE,.(COUNT_END_ATOMOX=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_INTERVENTION==TRUE&IS_ALPHA_ANTAGONIST,.(COUNT_END_ALPHA=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_FOLLOWUP==TRUE,.(COUNT_ACTIVE_END_FOLLOWUP=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_FOLLOWUP==TRUE&IS_TRUE_STIMULANT,.(COUNT_END_FOLLOWUP_STIMULANT=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_FOLLOWUP==TRUE&IS_ATOMOXETINE,.(COUNT_END_FOLLOWUP_ATOMOX=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_FOLLOWUP==TRUE&IS_ALPHA_ANTAGONIST,.(COUNT_END_FOLLOWUP_ALPHA=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_POST==TRUE,.(COUNT_ACTIVE_END_POST=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_POST==TRUE&IS_TRUE_STIMULANT,.(COUNT_END_POST_STIMULANT=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_POST==TRUE&IS_ATOMOXETINE,.(COUNT_END_POST_ATOMOX=.N),by=STUDY_ID][demog]
demog<-medications[ACTIVE_END_POST==TRUE&IS_ALPHA_ANTAGONIST,.(COUNT_END_POST_ALPHA=.N),by=STUDY_ID][demog]
demog[is.na(demog)]<-FALSE
#now apply the identification of visits onto DEMOG
demog[,VISIT_DURING_INTERVENTION_PERIOD:=STUDY_ID %in% visit[IN_INTERVENTION==TRUE]$STUDY_ID]
demog[,BH_VISIT_DURING_INTERVENTION_PERIOD:=STUDY_ID %in% visit[IN_INTERVENTION==TRUE&BH_VISIT]$STUDY_ID]
demog[,PCP_VISIT_DURING_INTERVENTION_PERIOD:=STUDY_ID %in% visit[IN_INTERVENTION==TRUE&!BH_VISIT&ADHD_VISIT]$STUDY_ID]
#MEDICATION BY DAY ANALYSIS ####
medications[,ITEM_INDEX:=.I]
demog_days<-demog[,list(AGE_DAYS=START_INTERVENTION_AGE:END_INTERVENTION_AGE,TIME_FRAME=1),by=STUDY_ID]
demog_days[,.SD,keyby=.(STUDY_ID,AGE_DAYS)] -> demog_days
med_days<-medications[STUDY_ID %in% demog_days$STUDY_ID,list(STUDY_ID,AGE_DAYS=MED_START_AGE_DAYS:MED_END_AGE_DAYS,IS_ALPHA_ANTAGONIST,IS_ATOMOXETINE,IS_TRUE_STIMULANT),by=ITEM_INDEX]
med_days[,IS_ON_MEDICATION:=IS_ALPHA_ANTAGONIST|IS_ATOMOXETINE|IS_TRUE_STIMULANT]
med_days[,.SD,keyby=.(STUDY_ID,AGE_DAYS)] -> med_days
demog_days<-med_days[,.(ACTIVE_MED_ON_DAY = max(IS_ON_MEDICATION)),keyby = .(STUDY_ID,AGE_DAYS)][demog_days]
demog_days_follow<-demog[,list(AGE_DAYS=START_FU_AGE:END_FU_AGE,TIME_FRAME=2),by=STUDY_ID]
demog_days_follow[,.SD,keyby=.(STUDY_ID,AGE_DAYS)] -> demog_days_follow
demog_days_follow<-med_days[,.(ACTIVE_MED_ON_DAY = max(IS_ON_MEDICATION)),keyby = .(STUDY_ID,AGE_DAYS)][demog_days_follow]
demog_days_post<-demog[,list(AGE_DAYS=START_POST_AGE:END_POST_AGE,TIME_FRAME=3),by=STUDY_ID]
demog_days_post[,.SD,keyby=.(STUDY_ID,AGE_DAYS)] -> demog_days_follow
demog_days_post<-med_days[,.(ACTIVE_MED_ON_DAY = max(IS_ON_MEDICATION)),keyby = .(STUDY_ID,AGE_DAYS)][demog_days_follow]
demog_days_combined<-as.data.table(rbind(demog_days,demog_days_follow,demog_days_post))
demog_days_combined[,.SD,keyby=.(STUDY_ID)] -> demog_days_combined
demog_days_combined<-as.data.table(rbind(demog_days,demog_days_follow,demog_days_post))
demog_days_follow
demog_days_follow<-demog[,list(AGE_DAYS=START_FU_AGE:END_FU_AGE,TIME_FRAME=2),by=STUDY_ID]
demog_days_post<-med_days[,.(ACTIVE_MED_ON_DAY = max(IS_ON_MEDICATION)),keyby = .(STUDY_ID,AGE_DAYS)][demog_days_post]
med_days<-medications[STUDY_ID %in% demog_days$STUDY_ID,list(STUDY_ID,AGE_DAYS=MED_START_AGE_DAYS:MED_END_AGE_DAYS,IS_ALPHA_ANTAGONIST,IS_ATOMOXETINE,IS_TRUE_STIMULANT),by=ITEM_INDEX]
med_days[,IS_ON_MEDICATION:=IS_ALPHA_ANTAGONIST|IS_ATOMOXETINE|IS_TRUE_STIMULANT]
med_days[,.SD,keyby=.(STUDY_ID,AGE_DAYS)] -> med_days
demog_days<-med_days[,.(ACTIVE_MED_ON_DAY = max(IS_ON_MEDICATION)),keyby = .(STUDY_ID,AGE_DAYS)][demog_days]
demog_days_follow<-demog[,list(AGE_DAYS=START_FU_AGE:END_FU_AGE,TIME_FRAME=2),by=STUDY_ID]
demog_days_follow[,.SD,keyby=.(STUDY_ID,AGE_DAYS)] -> demog_days_follow
demog_days_follow<-med_days[,.(ACTIVE_MED_ON_DAY = max(IS_ON_MEDICATION)),keyby = .(STUDY_ID,AGE_DAYS)][demog_days_follow]
demog_days_post<-demog[,list(AGE_DAYS=START_POST_AGE:END_POST_AGE,TIME_FRAME=3),by=STUDY_ID]
demog_days_post[,.SD,keyby=.(STUDY_ID,AGE_DAYS)] -> demog_days_follow
demog_days_post<-med_days[,.(ACTIVE_MED_ON_DAY = max(IS_ON_MEDICATION)),keyby = .(STUDY_ID,AGE_DAYS)][demog_days_post]
demog_days_post<-demog[,list(AGE_DAYS=START_POST_AGE:END_POST_AGE,TIME_FRAME=3),by=STUDY_ID]
demog_days_post[,.SD,keyby=.(STUDY_ID,AGE_DAYS)] -> demog_days_post
demog_days_post<-med_days[,.(ACTIVE_MED_ON_DAY = max(IS_ON_MEDICATION)),keyby = .(STUDY_ID,AGE_DAYS)][demog_days_post]
demog_days_combined<-as.data.table(rbind(demog_days,demog_days_follow,demog_days_post))
