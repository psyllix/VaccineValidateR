#coded data from review of vdx and rfv
rfv_coded <- as.data.table(read.csv(paste0("source-data/",file_header,"rfv-coded.csv"), stringsAsFactors = F))
vdx_coded <- as.data.table(read.csv(paste0("source-data/",file_header,"visit-dx-coded.csv"), stringsAsFactors = F))
dept_groups<-as.data.table(read.csv(paste0("source-data/",file_header,"dept-grp-coded.csv"), stringsAsFactors = F))
# KEY TABLES AND JOIN BACK data review content ####
rsn4visit[,.SD,keyby=.(REASON_VISIT_ID)] -> rsn4visit
rfv_coded[,.SD,keyby=.(REASON_VISIT_ID)] -> rfv_coded
rsn4visit<-rfv_coded[,.(ADHD_VISIT,WELL_VISIT,BH_VISIT,IF_DX_ADHD),keyby=.(REASON_VISIT_ID)][rsn4visit]
rm(rfv_coded)
dept_groups[,.SD,keyby=.(DEPT_NM)] -> dept_groups
visit[,.SD,keyby=.(DEPARTMENT_NAME)] -> visit
visit<-dept_groups[,.(DEPT_GRP=max(DEPT_GRP),DEPT_CLASS=max(DEPT_CLASS)),keyby=DEPT_NM][visit]
rm(dept_groups)
vdx[,.SD,keyby=.(CURRENT_ICD10_CODE)] -> vdx
vdx_coded[,.SD,keyby=.(ICD10_CD)] -> vdx_coded
vdx<-vdx_coded[,.(ADHD_DX=max(IS_ADHD==1),POSSIBLE_ADHD=max(NOT_OTHER_VISIT_REASON>=1)),keyby=.(ICD10_CD)][vdx]
rm(vdx_coded)
rsn4visit[,.SD,keyby=.(CSN)] -> rsn4visit
vdx[,.SD,keyby=.(CSN)] -> vdx
visit[,.SD,keyby=.(CSN)] -> visit
visit<-rsn4visit[,.(ADHD_VISIT=max(ADHD_VISIT),WELL_VISIT=max(WELL_VISIT),BH_VISIT=max(BH_VISIT),DX_NEEDED_RFV=max(IF_DX_ADHD)),keyby=.(CSN)][visit]
visit<-vdx[,.(ADHD_DX=max(ADHD_DX)),keyby=.(CSN)][visit]
rm(rsn4visit)
####initialize data####
demog[,STUDY_ID:=MRN]
medications[,STUDY_ID:=MRN]
study[,STUDY_ID:=MRN]
race[,STUDY_ID:=MRN]
visit[,STUDY_ID:=MRN]
coi[,STUDY_ID:=MRN]
demog[,.SD,keyby=.(STUDY_ID)] -> demog
race[,.SD,keyby=.(STUDY_ID)] -> race
medications[,.SD,keyby=.(STUDY_ID)] -> medications
visit[,.SD,keyby=.(STUDY_ID)] -> visit
study[,.SD,keyby=.(STUDY_ID)] -> study
coi[,.SD,keyby=.(STUDY_ID)] -> coi
visit<-visit[order(AGE_DAYS)]
visit[,ROW_INDEX:=.I]
visit[,FIRST_VISIT:=min(ROW_INDEX),by=STUDY_ID]
demog<-visit[ROW_INDEX==FIRST_VISIT,.(PAYOR_GRP=min(PAYOR_GRP),DEPT_NM=min(DEPT_NM),DEPT_GRP=min(DEPT_GRP),DEPT_CLASS=min(DEPT_CLASS)),keyby = STUDY_ID][demog]
