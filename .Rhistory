PRE_INTERVENTION_END_LOOKBACK<-30
#### PREPARE TO LOAD DATA #####
main_dir<-"C:/Users/michelj/OneDrive - Children's Hospital of Philadelphia/ADHD/ADHD-data/pcori-medication-status/"
file_header<-"pcori-medications-"
data_version<-"V3"
main_output_dir<-main_dir
setwd(paste0(main_dir,data_version))
# Cata input from EHR #####
demog <- as.data.table(read.csv(paste0("source-data/",file_header,"demog.csv"), stringsAsFactors = F))
medications <- as.data.table(read.csv(paste0("source-data/",file_header,"medications.csv"), stringsAsFactors = F))
race <- as.data.table(read.csv(paste0("source-data/",file_header,"race.csv"), stringsAsFactors = F))
visit <- as.data.table(read.csv(paste0("source-data/",file_header,"visit.csv"), stringsAsFactors = F))
rsn4visit <- as.data.table(read.csv(paste0("source-data/",file_header,"visit-cc.csv"), stringsAsFactors = F))
