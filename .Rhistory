,START_POST=as.Date(START_POST,format="%m/%d/%Y")
,END_POST=as.Date(END_POST,format="%m/%d/%Y")),keyby=STUDY_ID][demog]
#demog[is.na(START_INTERVENTION)==TRUE]#2 patient errors
demog[,CONDITION_TEXT:=as.factor(ifelse(CONDITION==0,"CONTROL","INTERVENTION"))]
demog$CONDITION<-factor(demog$CONDITION,factor(demog[,.N,by=CONDITION][order(CONDITION)]$CONDITION))
demog<-demog[!is.na(START_INTERVENTION)]#remove demog if not in dataset
demog[,START_INTERVENTION_AGE:=as.Date(START_INTERVENTION,format="%m/%d/%Y")-as.Date(DOB,format="%Y-%m-%d")]
demog[,START_FU_AGE:=as.Date(START_FU,format="%m/%d/%Y")-as.Date(DOB,format="%Y-%m-%d")]
demog[,END_INTERVENTION_AGE:=as.Date(END_INTERVENTION,format="%m/%d/%Y")-as.Date(DOB,format="%Y-%m-%d")]
demog[,END_FU_AGE:=as.Date(END_FU,format="%m/%d/%Y")-as.Date(DOB,format="%Y-%m-%d")]
demog[,START_POST_AGE:=as.Date(START_POST,format="%m/%d/%Y")-as.Date(DOB,format="%Y-%m-%d")]
demog[,END_POST_AGE:=as.Date(END_POST,format="%m/%d/%Y")-as.Date(DOB,format="%Y-%m-%d")]
#create a age (days) indicator for the start of the pre-intervention and end of pre-intervention periods
demog[,`:=`(PRE_INTERVENTION_PERIOD_START=START_INTERVENTION_AGE-PRE_INTERVENTION_START_LOOKBACK,PRE_INTERVENTION_PERIOD_END=START_INTERVENTION_AGE-PRE_INTERVENTION_END_LOOKBACK)]
visit<-visit[,EFFECTIVE_DATE:=as.Date(EFFECTIVE_DATE,format="%Y-%m-%d")]
visit<-demog[,.(REDCAP_ID,CONDITION,START_INTERVENTION,START_INTERVENTION_AGE,START_FU,START_FU_AGE,END_INTERVENTION,END_INTERVENTION_AGE,END_FU,END_FU_AGE,PRE_INTERVENTION_PERIOD_START,PRE_INTERVENTION_PERIOD_END),keyby=STUDY_ID][visit]
visit[,`:=`(IN_INTERVENTION=(EFFECTIVE_DATE>=START_INTERVENTION&EFFECTIVE_DATE<=END_INTERVENTION)
,PRE_INTERVENTION=(AGE_DAYS>=PRE_INTERVENTION_PERIOD_START&AGE_DAYS<=PRE_INTERVENTION_PERIOD_END)
,IN_FOLLOWUP=(EFFECTIVE_DATE>=START_FU&EFFECTIVE_DATE<=END_FU))]
