#MIMIC INSTALLATION OF PACKAGE UNTIL IT IS COMPLETED #####
library(devtools);
lib_dir<-"C:/Users/michelj/OneDrive - Children's Hospital of Philadelphia/git/VaccineValidateR/"
setwd(lib_dir);load_all(".")
devtools::check(args = c('--no-examples'))
#devtools::check(args = c('--no-examples'))#run check system
### FUNCTIONS TO SUPPORT EAL #####
startclock<-function(x) return(lubridate::now())
lapclock<-function(x) return(lubridate::now()-ts)
logging<-TRUE
#### PULL IN DATA #####
source_directory<-"C:/Users/michelj/OneDrive - Children's Hospital of Philadelphia/Immunizations/TIPP-C Immunization-Data/"
test_patients<-c(2734730,1934613,1212621)#recognized test patients to be removed
#load data
imm_complete <- data.table::as.data.table(read.csv(paste0(source_directory,"tippc-immunization-2025-02-27.csv"), stringsAsFactors = F),na.strings=c(""," ","NA"))
visits <- data.table::as.data.table(read.csv(paste0(source_directory,"tippc-visit-2025-03-21.csv"), stringsAsFactors = F),na.strings=c(""," ","NA"))
patients <- data.table::as.data.table(read.csv(paste0(source_directory,"tippc-patient-2025-03-21.csv"), stringsAsFactors = F),na.strings=c(""," ","NA"))
setwd(source_directory)
#realign variables
patients<-patients[,STUDY_ID:=SUBJECT_ID]
visits<-visits[,STUDY_ID:=SUBJECT_ID]
visits<-visits[,VISIT_ID:=.I]#add in visit ID
#antigens_list<-c('ALL')
#LIMIT TO PATIENTS OF INTEREST #####
#cohort<-patients[STUDY_ID == 1012]
#cohort<-head(patients[STUDY_ID %in% visits[VISIT_DATE > "2021"]$STUDY_ID],1000000)
cohort<-patients[STUDY_ID %in% visits[VISIT_DATE > "2021"]$STUDY_ID]#recently seen patients
visit_data<-visits[STUDY_ID %in% cohort$STUDY_ID]
immunization_data<-imm_complete[STUDY_ID %in% cohort$STUDY_ID]
?summarize_visits
?evaluate_visits
?VISIT_RETURN_COLUMNS
