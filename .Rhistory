vdx <- as.data.table(read.csv(paste0("source-data/",file_header,"visit-dx.csv"), stringsAsFactors = F))
coi <- as.data.table(read.csv(paste0("source-data/",file_header,"coi.csv"), stringsAsFactors = F))
