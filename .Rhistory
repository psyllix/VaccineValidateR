cb <- function(df, sep="\t", dec=".", max.size=(200*1000)){write.table(df, paste0("clipboard-", formatC(max.size, format="f", digits=0)), sep=sep, row.names=FALSE, dec=dec)}
cb(demog[,.(STUDY_ID,REDCAP_ID,MED_EPIC_START,MED_EPIC_END_INTERVENTION,MED_EPIC_END_FOLLOWUP,MED_EPIC_END_FOLLOWUP,STUDY_MED_UTILIZATION_RATE,FOLLOW_STUDY_MED_UTILIZATION_RATE,POST_STUDY_MED_UTILIZATION_RATE,GENERAL_MED_UTILIZATION_RATE)])
