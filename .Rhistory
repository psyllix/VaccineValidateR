imm_complete <- data.table::as.data.table(read.csv(paste0(source_directory,"tippc-immunization-2025-02-27.csv"), stringsAsFactors = F),na.strings=c(""," ","NA"))
visits <- data.table::as.data.table(read.csv(paste0(source_directory,"tippc-visit-2025-03-21.csv"), stringsAsFactors = F),na.strings=c(""," ","NA"))
patients <- data.table::as.data.table(read.csv(paste0(source_directory,"tippc-patient-2025-03-21.csv"), stringsAsFactors = F),na.strings=c(""," ","NA"))
