#### SELECT IMMUNIZATIONS ####
if(logging){ts<-startclock()}#under 1 minute
immunization_data<-select_immunizations(immunization_data=immunization_data,antigen_to_eval = 'ALL')
lapclock()
#### CLEAN PATIENT COHORT #####
if(logging){ts<-startclock()}#11 seconds for 2M patients
cohort<-create_cohort(cohort[!STUDY_ID %in% test_patients])
lapclock()
#### BUILD IMMUNIZATIONS #####
if(logging){ts<-startclock()}
output<-validate_immunizations(immunization_data = immunization_data,patients=cohort)
lapclock()
antigens<-output$antigens
antigens[,.N,by=ANTIGEN]
